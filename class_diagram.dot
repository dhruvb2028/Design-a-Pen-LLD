digraph PenModel {
    graph [
        rankdir=LR
        splines=ortho
        bgcolor="#FCFCFD"
        pad=0.45
        nodesep=0.9
        ranksep=1.0
        fontname="Arial"
        dpi=170
    ]

    node [
        shape=record
        style="filled,rounded"
        penwidth=1.6
        margin="0.24,0.12"
        fontname="Arial"
        fontsize=12
    ]

    edge [
        fontname="Arial"
        fontsize=10
        penwidth=1.4
        arrowsize=0.8
    ]

    Pen [
        label="{<<interface>>|Pen|+ start()\l+ write(text: String)\l+ close()\l+ refill()\l}"
        fillcolor="#EAF4FF"
        color="#2D6EA4"
    ]

    AbstractPen [
        label="{<<abstract>>|AbstractPen|# ink: Ink\l# state: PenState\l|getBrand()\l+getColor()\l+getState()\l#inkCostPerChar(): int\l}"
        fillcolor="#FFF2EA"
        color="#A0502B"
    ]

    BallpointPen [
        label="{BallpointPen|+ BallpointPen(brand, color)\l+ BallpointPen(brand, color, inkCapacity)\l}"
        fillcolor="#F3EDFF"
        color="#6A4BA3"
    ]

    FountainPen [
        label="{FountainPen|+ FountainPen(brand, color)\l+ FountainPen(brand, color, inkCapacity)\l}"
        fillcolor="#F3EDFF"
        color="#6A4BA3"
    ]

    Ink [
        label="{Ink|+ hasInk(): boolean\l+ consume(amount: int)\l+ refill()\l+ getLevel(): int\l+ getCapacity(): int\l}"
        fillcolor="#FFF8E7"
        color="#A98A12"
    ]

    PenState [
        label="{<<enum>>|PenState|OPEN\lCLOSED\lEMPTY\l}"
        fillcolor="#ECF9EF"
        color="#1D8656"
    ]

    { rank=same; BallpointPen; FountainPen }

    AbstractPen -> Pen [
        style=dashed
        arrowhead=empty
        color="#2D6EA4"
        fontcolor="#2D6EA4"
        label="realizes"
    ]

    BallpointPen -> AbstractPen [
        arrowhead=empty
        color="#6A4BA3"
        fontcolor="#6A4BA3"
        label="inherits"
    ]

    FountainPen -> AbstractPen [
        arrowhead=empty
        color="#6A4BA3"
        fontcolor="#6A4BA3"
        label="inherits"
    ]

    AbstractPen -> Ink [
        arrowhead=none
        arrowtail=diamond
        dir=both
        color="#A98A12"
        fontcolor="#A98A12"
        label="composition"
    ]

    AbstractPen -> PenState [
        style=dashed
        arrowhead=vee
        color="#1D8656"
        fontcolor="#1D8656"
        label="depends on"
    ]
}
